{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",  // ← 用toolkit（含electron-vite/node types）
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["electron-vite/node"]  // ← 加：nut.js Point等Node API类型
  },
  "include": ["src/main/**/*.ts", "src/backend/**/*.ts", "src/shared/**/*.ts", "electron.vite.config.*"]
}
